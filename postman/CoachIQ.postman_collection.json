{
  "info": {
    "_postman_id": "26a1f75d-bcb7-48e3-85b3-4af64a7f06d3",
    "name": "CoachIQ Backend",
    "description": "End-to-end collection for the current CoachIQ backend contract. It authenticates with the seeded admin user, exercises the main read and write APIs, and stores IDs between requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const now = new Date();",
          "const yyyy = now.getUTCFullYear();",
          "const mm = String(now.getUTCMonth() + 1).padStart(2, '0');",
          "const dd = String(now.getUTCDate()).padStart(2, '0');",
          "pm.environment.set('todayDate', `${yyyy}-${mm}-${dd}`);",
          "pm.environment.set('reportMonth', String(now.getUTCMonth() + 1));",
          "pm.environment.set('reportYear', String(now.getUTCFullYear()));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Health payload is successful', function () {",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.data.status).to.eql('ok');",
              "});",
              "['adminOtp', 'authToken', 'batchId', 'studentId', 'importedStudentId', 'testId'].forEach((key) => pm.environment.unset(key));",
              "const epoch = String(Date.now());",
              "pm.environment.set('runId', epoch.slice(-8));",
              "pm.environment.set('importParentPhone', `9${epoch.slice(-9)}`);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Request Admin OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('OTP request succeeded', function () {",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.data.phone).to.eql(pm.environment.get('adminPhone'));",
              "});",
              "pm.test('Debug OTP is exposed for automated local testing', function () {",
              "  pm.expect(json.data.debugOtp, 'Set EXPOSE_DEBUG_OTP=true for automated Postman runs').to.be.a('string');",
              "});",
              "pm.environment.set('adminOtp', json.data.debugOtp);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"{{adminPhone}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/request-otp",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "request-otp"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Verify Admin OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('OTP verification succeeded', function () {",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.data.token).to.be.a('string');",
              "  pm.expect(json.data.user.role).to.eql('ADMIN');",
              "});",
              "pm.environment.set('authToken', json.data.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"{{adminPhone}}\",\n  \"otp\": \"{{adminOtp}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/verify-otp",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "verify-otp"
          ]
        }
