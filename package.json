{
  "name": "coachiq-backend",
  "version": "0.1.0",
  "private": true,
  "description": "CoachIQ multi-tenant backend",
  "scripts": {
    "dev": "node --watch --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "seed": "node --import tsx prisma/seed.ts",
    "test:api": "newman run postman/CoachIQ.postman_collection.json -e postman/CoachIQ.local.postman_environment.json --reporters cli"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "node-cache": "^5.1.2",
    "prisma": "^6.8.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.17",
    "newman": "^6.2.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
